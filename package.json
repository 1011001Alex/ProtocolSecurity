{
  "name": "protocol-security",
  "version": "3.0.0-alpha",
  "description": "Protocol Security Architecture 3.0 - Enterprise-Grade Multi-Branch Security System with AI-Powered Threat Detection, Quantum-Resistant Cryptography, and 100% Test Coverage. Dual-Licensed under Apache-2.0/MIT.",
  "author": "Theodor Munch",
  "license": "Apache-2.0 OR MIT",
  "contributors": [
    {
      "name": "Theodor Munch",
      "email": "theodor.munch@protocol.local",
      "url": "https://github.com/1011001Alex"
    }
  ],
  "keywords": [
    "integrity",
    "security",
    "code-signing",
    "fim",
    "sbom",
    "slsa",
    "supply-chain",
    "transparency-log",
    "merkle-tree",
    "hash-chain",
    "threat-detection",
    "ueba",
    "mitre-attack",
    "threat-intelligence",
    "edr",
    "machine-learning"
  ],
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:unit": "jest --testPathPattern=unit",
    "test:integration": "jest --testPathPattern=integration",
    "test:threat": "jest --testPathPattern=threat",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run clean && npm run build && npm run test",
    "audit": "npm audit --audit-level=moderate",
    "audit:json": "npm audit --json > audit-report.json",
    "audit:fix": "npm audit fix",
    "audit:fix:force": "npm audit fix --force",
    "deps:check": "npm outdated",
    "deps:update": "npm update",
    "deps:update:latest": "npx npm-check-updates -u",
    "security:check": "npm audit && npm outdated",
    "security:full": "bash scripts/security-audit.sh --report",
    "deps:full": "bash scripts/dependency-check.sh --report",
    "snyk:test": "snyk test",
    "snyk:monitor": "snyk monitor"
  },
  "dependencies": {
    "@aws-sdk/client-cloudhsm": "^3.1024.0",
    "@aws-sdk/client-kms": "^3.1017.0",
    "@aws-sdk/client-secrets-manager": "^3.450.0",
    "@azure/identity": "^4.13.1",
    "@azure/keyvault-admin": "^4.7.0",
    "@azure/keyvault-certificates": "^4.10.0",
    "@azure/keyvault-keys": "^4.10.0",
    "@azure/keyvault-secrets": "^4.7.0",
    "@google-cloud/kms": "^5.4.0",
    "@google-cloud/secret-manager": "^4.0.0",
    "@simplewebauthn/server": "^13.3.0",
    "@tensorflow/tfjs": "^4.15.0",
    "@tensorflow/tfjs-node": "^4.15.0",
    "@types/bcrypt": "^6.0.0",
    "@types/geoip-lite": "^1.4.4",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/ua-parser-js": "^0.7.39",
    "argon2": "^0.44.0",
    "axios": "^1.6.0",
    "bcrypt": "^6.0.0",
    "chokidar": "^3.5.3",
    "elastic-apm-node": "^4.5.0",
    "express": "^5.2.1",
    "geoip-lite": "^1.4.10",
    "jose": "^6.2.2",
    "jsonwebtoken": "^9.0.3",
    "lodash": "^4.17.21",
    "node-cache": "^5.1.2",
    "otpauth": "^9.1.0",
    "stix": "^2.0.0",
    "ua-parser-js": "^2.0.9",
    "uuid": "^9.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/ioredis": "^4.28.10",
    "@types/jest": "^29.5.0",
    "@types/lodash": "^4.14.200",
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.45.0",
    "ioredis": "^5.10.1",
    "jest": "^29.6.0",
    "rimraf": "^5.0.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.1.0"
  },
  "repository": {
    "type": "git",
