# Git ignore file for Protocol Security
# Created by Theodor Munch

# =============================================================================
# SECURITY: Environment Files (NEVER COMMIT SECRETS!)
# =============================================================================
# .env files may contain passwords, tokens, and other sensitive data
# Always use secrets manager in production (AWS Secrets Manager, HashiCorp Vault)
# Development .env files are excluded but must not contain real credentials
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test
.env.staging
*.env

# Exceptions: .env.example is safe to commit (contains only placeholders)
!.env.example

# Explicitly ignore all secret-related files
*.pem
*.key
*.crt
*.p12
*.pfx
*.secret
*-secret.yaml
*-secret.yml
secrets.yaml
secrets.yml

# =============================================================================
# Dependencies
# =============================================================================
node_modules/
# package-lock.json — НЕ игнорировать! Нужен для CI/CD кэширования
# yarn.lock
# pnpm-lock.yaml

# Build output
dist/
build/
*.tsbuildinfo

# Environment files (IMPORTANT!)
.env
.env.local
.env.*.local
*.env

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# Test coverage
coverage/
.nyc_output/
test-results/

# Temporary files
tmp/
temp/
*.tmp
.cache/

# Docker (optional - keep configs, remove data)
*.tar
.docker/

# Kubernetes secrets (NEVER commit real secrets!)
k8s/secrets.yaml
*.secret.yaml

# Credentials
*.pem
*.key
*.crt
*.p12
*.pfx

# Backup files
*.bak
*.backup
*~

# Application specific
vault-data/
redis-data/
elasticsearch-data/
prometheus-data/
grafana-data/
