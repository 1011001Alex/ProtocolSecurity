# ===== CRYPTO SERVICE =====
CRYPTO_PROVIDER=aws-kms
CRYPTO_KEY_ID=arn:aws:kms:us-east-1:123456789012:key/your-key-id-here
CRYPTO_REGION=us-east-1

# ===== AUTH SERVICE =====
JWT_ISSUER=https://auth.protocol.local
JWT_AUDIENCE=api.protocol.local
JWT_EXPIRY=900
REFRESH_TOKEN_EXPIRY=604800
MFA_REQUIRED=true
SESSION_TIMEOUT=86400

# ===== REDIS (сессии, rate limiting) =====
REDIS_HOST=localhost
REDIS_PORT=6379
# ВНИМАНИЕ: Сгенерируйте криптографически стойкий пароль перед production deployment!
# Пример генерации: openssl rand -base64 32
# Минимальная длина: 32 символа, использовать буквы, цифры, специальные символы
REDIS_PASSWORD=your_secure_redis_password_here
REDIS_TLS_ENABLED=false

# ===== SECRETS MANAGER =====
SECRETS_BACKEND=vault
VAULT_URL=https://vault.local:8200
# ВНИМАНИЕ: Используйте HVS токен HashiCorp Vault с минимальными привилегиями
# Никогда не коммитьте реальные токены в git!
# Генерация: vault token create -policy="your-policy" -ttl=720h
VAULT_TOKEN=hvs.your_vault_token_here_generate_before_production
VAULT_NAMESPACE=admin

# ===== LOGGING & SIEM =====
LOG_LEVEL=INFO
ELASTICSEARCH_HOST=https://es.local:9200
ELASTICSEARCH_USER=elastic
# ВНИМАНИЕ: Смените пароль Elasticsearch перед production!
# Минимальная длина: 20 символов, использовать password manager
ELASTICSEARCH_PASSWORD=change_this_password_before_production
SIEM_ENABLED=true

# ===== THREAT DETECTION =====
ML_ENABLED=true
THREAT_INTEL_ENABLED=true
STIX_TAXII_URL=https://taxii.mitre.org/api/v2.1/

# ===== ZERO TRUST =====
ZTNA_ENABLED=true
MTLS_ENABLED=true
CERTIFICATE_AUTHORITY=your-ca-name

# ===== INCIDENT RESPONSE =====
# ВНИМАНИЕ: Сгенерируйте уникальные webhook URL и токены для вашего workspace
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
PAGERDUTY_ROUTING_KEY=your-pagerduty-routing-key
JIRA_URL=https://your-company.atlassian.net
# ВНИМАНИЕ: Используйте API token с минимальными permissions (только чтение/запись issues)
JIRA_API_TOKEN=your-jira-api-token-generate-in-atlassian-settings

# ===== ENVIRONMENT =====
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# ===== CORS CONFIGURATION =====
# Режим CORS (public, private, dev, apiGateway, microservice)
CORS_MODE=dev

# Разрешённые origins (через запятую для нескольких доменов)
# Пример: CORS_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ORIGINS=*

# Разрешённые HTTP методы
CORS_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS

# Разрешённые заголовки
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With,X-Request-ID

# Открываемые заголовки (клиент может читать)
CORS_EXPOSED_HEADERS=X-Request-ID,X-RateLimit-Limit,X-RateLimit-Remaining

# Разрешить credentials (cookies, authorization headers)
# true - только для конкретных origins, false - для wildcard (*)
CORS_CREDENTIALS=false

# Максимальный возраст кэша preflight запросов (в секундах)
# 86400 = 24 часа, максимум 2592000 (30 дней)
CORS_MAX_AGE=86400

# Продолжать выполнение после preflight (для Express)
CORS_PREFLIGHT_CONTINUE=false

# Статус код для успешного preflight запроса
CORS_OPTIONS_SUCCESS_STATUS=204

# Строгий режим CORS (валидировать origin строго)
CORS_STRICT=false

# Чёрный список origins (всегда блокировать)
# Пример: CORS_BLACKLIST=https://malicious.com,*.evil.com
CORS_BLACKLIST=

# Динамическое отражение origin (использовать с осторожностью!)
# true - отражать origin из запроса (только для dev)
CORS_DYNAMIC_ORIGIN=false
