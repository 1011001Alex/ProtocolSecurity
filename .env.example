# ===== CRYPTO SERVICE =====
CRYPTO_PROVIDER=aws-kms
CRYPTO_KEY_ID=arn:aws:kms:us-east-1:123456789012:key/your-key-id-here
CRYPTO_REGION=us-east-1

# ===== AUTH SERVICE =====
JWT_ISSUER=https://auth.protocol.local
JWT_AUDIENCE=api.protocol.local
JWT_EXPIRY=900
REFRESH_TOKEN_EXPIRY=604800
MFA_REQUIRED=true
SESSION_TIMEOUT=86400

# ===== JWT BLACKLIST =====
# Конфигурация blacklist для отозванных JWT токенов
# Реализует: отзыв токенов при logout, смене пароля, security incidents

# Включить ли JWT blacklist
# true - проверять все токены против blacklist (рекомендуется для production)
# false - отключить проверку blacklist (не рекомендуется)
JWT_BLACKLIST_ENABLED=true

# Префикс для ключей Redis blacklist
# Используется для изоляции данных в общем Redis
# Пример: JWT_BLACKLIST_PREFIX=protocol:jwt:blacklist:
JWT_BLACKLIST_PREFIX=protocol:jwt:blacklist:

# Префикс для индексов по userId
# Хранит mapping: userId -> [tokenId1, tokenId2, ...]
# Позволяет массово отзывать токены пользователя
JWT_BLACKLIST_USER_INDEX_PREFIX=protocol:jwt:blacklist:user:

# Префикс для индексов по deviceId
# Хранит mapping: deviceId -> [tokenId1, tokenId2, ...]
# Позволяет массово отзывать токены устройства
JWT_BLACKLIST_DEVICE_INDEX_PREFIX=protocol:jwt:blacklist:device:

# Интервал автоматической очистки просроченных записей (мс)
# Рекомендуется: 3600000 (1 час) для production
# Минимальное значение: 60000 (1 минута)
# Максимальное значение: 86400000 (24 часа)
JWT_BLACKLIST_CLEANUP_INTERVAL=3600000

# Максимальный размер метрик (количество записей)
# Ограничивает память для хранения статистики
# Рекомендуется: 10000 для production
JWT_BLACKLIST_MAX_METRICS_SIZE=10000

# Режим при ошибке Redis
# fail-open - разрешать токены при ошибке (доступность > безопасность)
# fail-close - запрещать токены при ошибке (безопасность > доступность)
# Рекомендуется: fail-open для высокой доступности
JWT_BLACKLIST_ERROR_MODE=fail-open

# ===== REDIS (сессии, rate limiting) =====
REDIS_HOST=localhost
REDIS_PORT=6379
# ВНИМАНИЕ: Сгенерируйте криптографически стойкий пароль перед production deployment!
# Пример генерации: openssl rand -base64 32
# Минимальная длина: 32 символа, использовать буквы, цифры, специальные символы
REDIS_PASSWORD=your_secure_redis_password_here
REDIS_TLS_ENABLED=false

# ===== SECRETS MANAGER =====
SECRETS_BACKEND=vault
VAULT_URL=https://vault.local:8200
# ВНИМАНИЕ: Используйте HVS токен HashiCorp Vault с минимальными привилегиями
# Никогда не коммитьте реальные токены в git!
# Генерация: vault token create -policy="your-policy" -ttl=720h
VAULT_TOKEN=hvs.your_vault_token_here_generate_before_production
VAULT_NAMESPACE=admin

# ===== LOGGING & SIEM =====
LOG_LEVEL=INFO
ELASTICSEARCH_HOST=https://es.local:9200
ELASTICSEARCH_USER=elastic
# ВНИМАНИЕ: Сгенерируйте уникальный пароль перед production deployment!
# Пример генерации: openssl rand -base64 32
# Минимальная длина: 32 символа, использовать password manager
# Для production используйте secrets manager:
#   AWS: aws secretsmanager get-secret-value --secret-id prod/elasticsearch/password
#   Vault: vault kv get -field=password secret/elasticsearch
ELASTICSEARCH_PASSWORD=your_secure_elasticsearch_password_here
SIEM_ENABLED=true

# ===== THREAT DETECTION =====
ML_ENABLED=true
THREAT_INTEL_ENABLED=true
STIX_TAXII_URL=https://taxii.mitre.org/api/v2.1/

# ===== ZERO TRUST =====
ZTNA_ENABLED=true
MTLS_ENABLED=true
CERTIFICATE_AUTHORITY=your-ca-name

# ===== INCIDENT RESPONSE =====
# ВНИМАНИЕ: Сгенерируйте уникальные webhook URL и токены для вашего workspace
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
PAGERDUTY_ROUTING_KEY=your-pagerduty-routing-key
JIRA_URL=https://your-company.atlassian.net
# ВНИМАНИЕ: Используйте API token с минимальными permissions (только чтение/запись issues)
JIRA_API_TOKEN=your-jira-api-token-generate-in-atlassian-settings

# ===== ENVIRONMENT =====
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# ===== CORS CONFIGURATION =====
# Режим CORS (public, private, dev, apiGateway, microservice)
CORS_MODE=dev

# Разрешённые origins (через запятую для нескольких доменов)
# Пример: CORS_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ORIGINS=*

# ===== CIRCUIT BREAKER CONFIGURATION =====
# Circuit Breaker для Redis и внешних сервисов
# Защита от каскадных отказов, автоматическое восстановление

# Максимальное количество failures перед разрывом цепи
# Рекомендуемое значение: 3-10 для production, 1-2 для testing
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5

# Таймаут перед попыткой восстановления соединения (ms)
# Рекомендуемое значение: 30000-60000 (30-60 секунд)
CIRCUIT_BREAKER_RESET_TIMEOUT=30000

# Количество успешных операций для замыкания цепи в HALF_OPEN состоянии
# Рекомендуемое значение: 2-5
CIRCUIT_BREAKER_SUCCESS_THRESHOLD=3

# Таймаут для отдельных операций (ms)
# Рекомендуемое значение: 5000-15000 (5-15 секунд)
CIRCUIT_BREAKER_OPERATION_TIMEOUT=10000

# Включить мониторинг circuit breaker (логирование событий)
CIRCUIT_BREAKER_ENABLE_MONITORING=true

# ===== RETRY CONFIGURATION =====
# Exponential backoff retry logic для transient ошибок

# Максимальное количество retry попыток
# Рекомендуемое значение: 3-5 для production, 1-2 для testing
CIRCUIT_BREAKER_RETRY_MAX_ATTEMPTS=3

# Начальная задержка между попытками (ms)
# Рекомендуемое значение: 100-500ms
CIRCUIT_BREAKER_RETRY_INITIAL_DELAY=100

# Максимальная задержка между попытками (ms)
# Рекомендуемое значение: 5000-10000 (5-10 секунд)
CIRCUIT_BREAKER_RETRY_MAX_DELAY=5000

# Множитель для exponential backoff
# Рекомендуемое значение: 2 (каждая задержка удваивается)
CIRCUIT_BREAKER_RETRY_MULTIPLIER=2

# Фактор jitter (0.0-1.0) для предотвращения thundering herd
# Рекомендуемое значение: 0.1-0.3
CIRCUIT_BREAKER_RETRY_JITTER=0.2

# Стратегия backoff: FIXED, LINEAR, EXPONENTIAL, EXPONENTIAL_WITH_JITTER
CIRCUIT_BREAKER_RETRY_STRATEGY=EXPONENTIAL_WITH_JITTER

# Разрешённые HTTP методы
CORS_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS

# Разрешённые заголовки
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With,X-Request-ID

# Открываемые заголовки (клиент может читать)
CORS_EXPOSED_HEADERS=X-Request-ID,X-RateLimit-Limit,X-RateLimit-Remaining

# Разрешить credentials (cookies, authorization headers)
# true - только для конкретных origins, false - для wildcard (*)
CORS_CREDENTIALS=false

# Максимальный возраст кэша preflight запросов (в секундах)
# 86400 = 24 часа, максимум 2592000 (30 дней)
CORS_MAX_AGE=86400

# Продолжать выполнение после preflight (для Express)
CORS_PREFLIGHT_CONTINUE=false

# Статус код для успешного preflight запроса
CORS_OPTIONS_SUCCESS_STATUS=204

# Строгий режим CORS (валидировать origin строго)
CORS_STRICT=false

# Чёрный список origins (всегда блокировать)
# Пример: CORS_BLACKLIST=https://malicious.com,*.evil.com
CORS_BLACKLIST=

# Динамическое отражение origin (использовать с осторожностью!)
# true - отражать origin из запроса (только для dev)
CORS_DYNAMIC_ORIGIN=false

# ===== INPUT VALIDATION CONFIGURATION =====
# Валидация всех входящих запросов, защита от injection атак

# Включить валидацию входных данных
# true - валидировать все POST/PUT/PATCH запросы
# false - отключить валидацию (не рекомендуется для production)
ENABLE_INPUT_VALIDATION=true

# Строгий режим валидации
# true - блокировать запрос при любых ошибках валидации
# false - продолжать выполнение, добавлять ошибки в request.validationResult
# Рекомендуется для production: true
INPUT_VALIDATION_STRICT_MODE=false

# Максимальный размер тела запроса (в байтах)
# По умолчанию: 10MB (10485760 байт)
# Для API с большими файлами можно увеличить
# Для микросервисов с маленькими payload можно уменьшить
INPUT_VALIDATION_MAX_BODY_SIZE=10485760

# Санитизация HTML в строковых полях
# true - заменять HTML специальные символы на entities (&lt;, &gt;, etc.)
# false - оставлять HTML без изменений (только injection проверка)
# Рекомендуется для production: true (защита от XSS)
INPUT_VALIDATION_SANITIZE_HTML=true

# Включить rate limiting для валидации
# true - ограничивать количество запросов на валидацию
# false - без ограничений (rate limiting обрабатывается в RateLimitMiddleware)
# Примечание: обычно используется отдельный RateLimitMiddleware
INPUT_VALIDATION_ENABLE_RATE_LIMIT=false

# Максимальное количество запросов на валидацию в минуту (для rate limiting)
# Рекомендуемое значение: 100-1000 для production
INPUT_VALIDATION_RATE_LIMIT_MAX=100

# Окно rate limiting для валидации (мс)
# Рекомендуемое значение: 60000 (1 минута)
INPUT_VALIDATION_RATE_LIMIT_WINDOW_MS=60000

# Логирование ошибок валидации
# true - логировать все ошибки валидации через SecureLogger
# false - не логировать (ошибки только в ответе клиенту)
INPUT_VALIDATION_LOG_ERRORS=true

# Уровень логирования для валидации
# DEBUG, INFO, WARNING, ERROR, CRITICAL
INPUT_VALIDATION_LOG_LEVEL=WARNING

# Пропускать определенные пути (regex паттерны через запятую)
# Пример: ^/api/public,^/health,^/metrics
INPUT_VALIDATION_SKIP_PATHS=

# Пропускать определенные HTTP методы (через запятую)
# По умолчанию: GET,HEAD,OPTIONS (не требуют валидации body)
INPUT_VALIDATION_SKIP_METHODS=GET,HEAD,OPTIONS

# ===== HEALTH CHECK CONFIGURATION =====
# Система проверки здоровья сервисов для Kubernetes и мониторинга
# Реализует: liveness probe, readiness probe, Prometheus metrics

# Включить health checks
# true - активировать health check endpoints и периодические проверки
# false - отключить health checks (не рекомендуется для production)
# Рекомендуется для production: true
HEALTH_CHECK_ENABLED=true

# Интервал периодических проверок (мс)
# Проверяет все зависимости: Redis, Database, Vault, Elasticsearch
# Рекомендуется для production: 10000-30000 (10-30 секунд)
# Для testing можно меньше: 5000 (5 секунд)
HEALTH_CHECK_INTERVAL=10000

# Таймаут проверки Redis подключения (мс)
# Максимальное время ожидания ответа от Redis
# Рекомендуется для production: 3000-5000 (3-5 секунд)
HEALTH_CHECK_REDIS_TIMEOUT=5000

# Таймаут проверки Database подключения (мс)
# Максимальное время ожидания ответа от БД
# Рекомендуется для production: 3000-5000 (3-5 секунд)
HEALTH_CHECK_DATABASE_TIMEOUT=5000

# Таймаут проверки Vault API (мс)
# Максимальное время ожидания ответа от HashiCorp Vault
# Рекомендуется для production: 5000-10000 (5-10 секунд)
HEALTH_CHECK_VAULT_TIMEOUT=5000

# Таймаут проверки Elasticsearch API (мс)
# Максимальное время ожидания ответа от Elasticsearch
# Рекомендуется для production: 5000-10000 (5-10 секунд)
HEALTH_CHECK_ELASTICSEARCH_TIMEOUT=5000

# Порог предупреждения для памяти (%)
# При превышении статуса компонента становится WARNING
# Рекомендуется для production: 80-85
HEALTH_CHECK_MEMORY_WARNING_THRESHOLD=80

# Порог критического состояния для памяти (%)
# При превышении статуса компонента становится UNHEALTHY
# Рекомендуется для production: 90-95
HEALTH_CHECK_MEMORY_CRITICAL_THRESHOLD=95

# Порог предупреждения для CPU (%)
# При превышении статуса компонента становится WARNING
# Рекомендуется для production: 70-80
HEALTH_CHECK_CPU_WARNING_THRESHOLD=70

# Порог критического состояния для CPU (%)
# При превышении статуса компонента становится UNHEALTHY
# Рекомендуется для production: 90-95
HEALTH_CHECK_CPU_CRITICAL_THRESHOLD=90

# Включить Prometheus metrics endpoint
# true - активировать /health/prometheus endpoint
# false - отключить сбор метрик Prometheus
# Рекомендуется для production: true
HEALTH_CHECK_ENABLE_PROMETHEUS=true

# Порт для Prometheus metrics (если выделенный сервер)
# По умолчанию используется тот же порт что и API
# Оставьте 9090 если не используете выделенный metrics сервер
HEALTH_CHECK_PROMETHEUS_PORT=9090

# ===== ENDPOINTS =====
# После активации health check становятся доступны:
# GET /health - базовая проверка (Kubernetes liveness)
# GET /health/detailed - детальная проверка всех компонентов
# GET /ready - проверка готовности принимать трафик (Kubernetes readiness)
# GET /live - проверка что приложение живо (Kubernetes liveness)
# GET /health/prometheus - метрики в формате Prometheus
# GET /health/cached - кэшированный результат последней проверки
